							"raw": "{\n    \"name\": \"Testing User\",\n    \"email\": \"test@playmate.com\",\n    \"password\": \"password123\",\n    \"age\": 24,\n    \"gender\": \"Male\",\n    \"sports_interests\": [\"Golf\"],\n    \"skill_level\": \"Beginner\",\n    \"lon\": -122.4200,\n    \"lat\": 37.7700,\n    \"bio\": \"Test profile\"\n}"
